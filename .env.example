# Host port exposed by Docker Compose. The app still listens on port 8000 inside the container.
HOST_PORT=8000

# Public URL used in account verification emails.
APP_BASE_URL=https://arcaneledger.example.com

# Security timeouts.
SESSION_IDLE_MINUTES=30
EMAIL_VERIFICATION_MINUTES=30
PASSWORD_RESET_MINUTES=30

# Optional comma-separated fallback admins. Leave blank for normal self-hosted
# installs; the first account should use Claim Server instead.
ADMIN_EMAILS=

# Scryfall import guardrails.
# Large CSV imports can create many lookup requests. These defaults keep imports friendly
# to Scryfall and reduce reverse-proxy 504s. Raise the limit only if your proxy timeout
# is also high enough.
SCRYFALL_TIMEOUT_SECONDS=15
SCRYFALL_IMPORT_LOOKUP_LIMIT=80
SCRYFALL_IMPORT_LOOKUP_DELAY=0.12

# Email via SMTP. Recommended for Mailgun SMTP credentials.
# Copy this file to .env and fill these in on the machine running Docker Compose.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=Arcane Ledger
SMTP_AUTH_METHOD=
SMTP_SECURE=false
SMTP_STARTTLS=true

# Optional SMTP aliases. These are useful if you already have Laravel-style mail settings.
# If both SMTP_* and MAIL_* are set, SMTP_* wins.
MAIL_DRIVER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=Arcane Ledger
MAIL_AUTH_METHOD=

# Optional Mailgun API fallback. Leave blank if you use SMTP.
# US: https://api.mailgun.net/v3
# EU: https://api.eu.mailgun.net/v3
MAILGUN_API_BASE=https://api.mailgun.net/v3
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=
MAILGUN_FROM_NAME=Arcane Ledger

# Debug logging. Defaults write to ./data/logs/arcaneledger.log through Docker.
LOG_LEVEL=INFO
LOG_MAX_BYTES=2097152
LOG_BACKUP_COUNT=5
